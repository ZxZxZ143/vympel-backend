<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="2026-02-08-05-drop-country-from-brand" author="admin">

        <preConditions onFail="MARK_RAN">
            <columnExists tableName="brand" columnName="country_id"/>
        </preConditions>

        <dropForeignKeyConstraint
                baseTableName="brand"
                constraintName="fk_brand_country"/>

        <dropColumn tableName="brand" columnName="country_id"/>

    </changeSet>

</databaseChangeLog>
