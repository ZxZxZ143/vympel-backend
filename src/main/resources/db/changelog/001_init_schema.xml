            </column>
            <column name="lang" type="VARCHAR(5)">
                <constraints nullable="false"/>
            </column>
            <column name="alt_text" type="VARCHAR(255)"/>
        </createTable>

        <addPrimaryKey tableName="media_i18n" columnNames="media_id,lang" constraintName="pk_media_i18n"/>
        <addForeignKeyConstraint baseTableName="media_i18n" baseColumnNames="media_id"
                                 referencedTableName="media" referencedColumnNames="id"
                                 constraintName="fk_media_i18n" onDelete="CASCADE"/>

        <sql>
            ALTER TABLE media_i18n
                ADD CONSTRAINT chk_media_i18n_lang CHECK (lang IN ('ru', 'en', 'kk'));
        </sql>
